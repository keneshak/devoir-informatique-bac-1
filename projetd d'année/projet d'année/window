def charger_fichier(chemin):
    if os.path.exists(chemin):
        with open(chemin, "r") as f:
            return f.read().splitlines()
    else:
        return [""]   
    
if len(sys.argv) > 1:
    chemin = sys.argv[1]
    buffer = charger_fichier(chemin)
else:
    chemin = None
    buffer = [""]
    
def executer_commande(cmd, buffer):
    parts = cmd.split()

    if len(parts) >= 2 and parts[0] in ["open", "o"]:
        chemin = parts[1]
        return charger_fichier(chemin), chemin

    return buffer, None

